# ── Outlook Dispatch ──────────────────────────────────────────────────────────
# Your Outlook.com address — used as the sender identity for Outlook Web dispatch.
# Run `python main.py --setup-sender` once to save the browser session.
SMTP_ADDRESS=
DAILY_EMAIL_CAP=80

# ── Discovery flush threshold ─────────────────────────────────────────────────
# Write discovered URLs to DB after this many accumulate in the buffer.
# Lower = more crash-safe. Higher = fewer DB writes per run.
DISCOVERY_FLUSH_EVERY=50

# ── Discovery pass cooldown ───────────────────────────────────────────────────
# Seconds to pause between discovery passes (lets rate-limits recover).
DISCOVERY_PASS_DELAY=300

# ── Search engine ─────────────────────────────────────────────────────────────
# Options: brave | google | bing | duckduckgo
SEARCH_ENGINE=brave

# ── Browser engine (Playwright) ───────────────────────────────────────────────
# Options: firefox | chromium | webkit
BROWSER_ENGINE=firefox

# ── Auth timeout — seconds to wait for user input before skipping a site ──────
AUTH_PROMPT_TIMEOUT=60

# ── Portfolio link (optional) ─────────────────────────────────────────────────
# When set, appended to every email body as a code-sample reference link.
PORTFOLIO_URL=

# ── Test mode (optional) ─────────────────────────────────────────────────────
# When set, all outgoing emails are redirected to this address instead of the
# real lead recipient. Everything else (scraping, copywriting, DB) runs normally.
TEST_RECIPIENT_EMAIL=

# ── Authenticated sites (populated automatically by auth_bootstrap) ────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Add further sites as they are bootstrapped:
# WELLFOUND_EMAIL=
# WELLFOUND_PASSWORD=
