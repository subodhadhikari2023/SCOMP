# ── Gemini LLM ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── SMTP Dispatch (Outlook) ───────────────────────────────────────────────────
SMTP_ADDRESS=
SMTP_PASSWORD=
DAILY_EMAIL_CAP=80

# ── Discovery flush threshold ─────────────────────────────────────────────────
# Write discovered URLs to DB after this many accumulate in the buffer.
# Lower = more crash-safe. Higher = fewer DB writes per run.
DISCOVERY_FLUSH_EVERY=50

# ── Search engine ─────────────────────────────────────────────────────────────
# Options: bing | duckduckgo
SEARCH_ENGINE=bing

# ── Browser engine (Playwright) ───────────────────────────────────────────────
# Options: firefox | chromium | webkit
BROWSER_ENGINE=firefox

# ── Auth timeout — seconds to wait for user input before skipping a site ──────
AUTH_PROMPT_TIMEOUT=60

# ── Authenticated sites (populated automatically by auth_bootstrap) ────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Add further sites as they are bootstrapped:
# WELLFOUND_EMAIL=
# WELLFOUND_PASSWORD=
